d:["$","$L14",null,{"type":"single","collapsible":true,"className":"space-y-3","children":[["$","$L15","0",{"value":"item-0","className":"bg-card border border-border rounded-xl px-6 data-[state=open]:border-foreground/30","children":[["$","$L16",null,{"className":"text-left text-base font-medium text-foreground hover:no-underline py-5","children":"Hành trình tự kiểm chứng mùi hương — Vì sao có mùi hợp ngay, có mùi lại không?"}],["$","$L17",null,{"className":"text-muted-foreground pb-5 leading-relaxed text-sm","children":"Mỗi mùi hương sẽ lên da khác nhau do nhiệt độ cơ thể, pH da, khí hậu, và cả thói quen sinh hoạt hằng ngày. Vì vậy cùng một chai nước hoa nhưng người này thấy rất hợp, người khác lại thấy chưa đúng gu. Cách chọn hiệu quả nhất là test trên da thật, đợi 30-60 phút để mùi ổn định rồi mới quyết định. ADNz có thể gợi ý theo nhóm mùi, môi trường sử dụng và ngân sách để bạn chọn đúng ngay từ đầu."}]]}],["$","$L15","1",{"value":"item-1","className":"bg-card border border-border rounded-xl px-6 data-[state=open]:border-foreground/30","children":[["$","$L16",null,{"className":"text-left text-base font-medium text-foreground hover:no-underline py-5","children":"ADNz có bán hàng chính hãng không?"}],["$","$L17",null,{"className":"text-muted-foreground pb-5 leading-relaxed text-sm","children":"ADNz tập trung các dòng nước hoa chính hãng, được kiểm tra kỹ càng trước khi được gửi đến tay khách hàng. Nếu cần tư vấn mùi theo ngân sách hoặc phong cách, đội ngũ sẽ hỗ trợ trực tiếp."}]]}],["$","$L15","2",{"value":"item-2","className":"bg-card border border-border rounded-xl px-6 data-[state=open]:border-foreground/30","children":[["$","$L16",null,{"className":"text-left text-base font-medium text-foreground hover:no-underline py-5","children":"Mình muốn đăng ký CTV/Sỉ thì làm sao?"}],["$","$L17",null,{"className":"text-muted-foreground pb-5 leading-relaxed text-sm","children":"Bạn bấm vào nút “Wholesale & Reseller”, điền SĐT Zalo + email + link kênh bán hàng. Hệ thống sẽ gửi xác nhận tự động và ADNz sẽ liên hệ lại để duyệt hồ sơ hợp tác."}]]}],["$","$L15","3",{"value":"item-3","className":"bg-card border border-border rounded-xl px-6 data-[state=open]:border-foreground/30","children":[["$","$L16",null,{"className":"text-left text-base font-medium text-foreground hover:no-underline py-5","children":"Bao lâu mình nhận được phản hồi sau khi đăng ký?"}],["$","$L17",null,{"className":"text-muted-foreground pb-5 leading-relaxed text-sm","children":"Thông thường trong ngày làm việc. Trường hợp đăng ký ngoài giờ cao điểm, đội ngũ sẽ phản hồi vào khung giờ làm việc gần nhất qua Zalo hoặc email bạn đã để lại."}]]}],["$","$L15","4",{"value":"item-4","className":"bg-card border border-border rounded-xl px-6 data-[state=open]:border-foreground/30","children":[["$","$L16",null,{"className":"text-left text-base font-medium text-foreground hover:no-underline py-5","children":"Có hỗ trợ ship toàn quốc không?"}],["$","$L17",null,{"className":"text-muted-foreground pb-5 leading-relaxed text-sm","children":"Có. ADNz hỗ trợ giao hàng toàn quốc. Thời gian nhận hàng tùy khu vực và đơn vị vận chuyển, bạn sẽ được báo dự kiến giao hàng trước khi chốt đơn."}]]}],["$","$L15","5",{"value":"item-5","className":"bg-card border border-border rounded-xl px-6 data-[state=open]:border-foreground/30","children":[["$","$L16",null,{"className":"text-left text-base font-medium text-foreground hover:no-underline py-5","children":"Có được đổi mùi hoặc hỗ trợ sau mua không?"}],["$","$L17",null,{"className":"text-muted-foreground pb-5 leading-relaxed text-sm","children":"ADNz có hỗ trợ sau mua theo tình trạng sản phẩm và chính sách từng thời điểm. Bạn nên liên hệ sớm qua kênh chăm sóc để được xử lý nhanh nhất."}]]}],["$","$L15","6",{"value":"item-6","className":"bg-card border border-border rounded-xl px-6 data-[state=open]:border-foreground/30","children":["$L18","$L19"]}]]}]
